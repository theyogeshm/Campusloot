# =============================================================================
# CampusLoot Backend — Environment Variables
# Copy this file to backend/.env and fill in your real values.
# ⚠️  NEVER commit your actual .env file to version control.
# =============================================================================

# PORT: Port on which the Express server listens (default: 5000)
PORT=5000

# NODE_ENV: "development" | "production"
NODE_ENV=development

# MONGO_URI: Full MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/campusloot?retryWrites=true&w=majority

# JWT_SECRET: Secret key used to sign and verify JSON Web Tokens.
# ⚠️  MUST be at least 32 characters. Use a cryptographically random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_CRYPTOGRAPHICALLY_RANDOM_96_CHAR_HEX_STRING

# SUPER_ADMIN_EMAIL: The email address treated as super-admin in auth responses.
SUPER_ADMIN_EMAIL=admin@example.com

# FRONTEND_URL: Production URL of the frontend — added to the CORS allowed-origins list.
# In development leave this empty; localhost:3000 / 4321 / 5173 are already whitelisted.
# Example: https://campusloot.com
FRONTEND_URL=

# ADMIN_EMAIL / ADMIN_PASSWORD: Used only by seeding scripts (never by the running server).
# ⚠️  Do NOT use a real password here — this is only for local DB seed scripts.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

