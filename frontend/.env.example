# =============================================================================
# CampusLoot — Unified Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit your actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (Vite / React)
# -----------------------------------------------------------------------------

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (used for OAuth callbacks, self-links, etc.)
APP_URL="http://localhost:3000"

# VITE_API_BASE_URL: Base URL that the React frontend uses to call the backend API.
# In development this points to the local Express server.
VITE_API_BASE_URL="http://localhost:5000/api"

# -----------------------------------------------------------------------------
# BACKEND (Node / Express / MongoDB)
# -----------------------------------------------------------------------------

# PORT: Port on which the Express server will listen.
PORT=5000

# NODE_ENV: "development" | "production"
NODE_ENV="development"

# MONGO_URI: Full MongoDB Atlas connection string.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/campusloot?retryWrites=true&w=majority"

# JWT_SECRET: Secret key used to sign and verify JSON Web Tokens.
# Use a long, random string (e.g. generated with: openssl rand -base64 64)
JWT_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING"

# SUPER_ADMIN_EMAIL: The email address that automatically receives admin privileges on first signup.
SUPER_ADMIN_EMAIL="admin@example.com"

# FRONTEND_URL: Production URL of the frontend (added to the CORS allowed-origins list).
# Leave empty in development; CORS already allows localhost:3000 / localhost:4321 / localhost:5173.
FRONTEND_URL=""
